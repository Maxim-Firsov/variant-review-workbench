<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ page_title }}</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='site.css') }}">
  </head>
  <body>
    <div class="shell">
      <header class="topbar">
        <a class="brand" href="{{ url_for('home') }}">Review Workbench</a>
        <nav class="nav" aria-label="Primary">
          <a href="{{ url_for('home') }}" class="{% if current_page == 'home' %}active{% endif %}">Home</a>
          <a href="{{ url_for('docs') }}" class="{% if current_page == 'docs' %}active{% endif %}">ReadMe</a>
        </nav>
      </header>
      {% block content %}{% endblock %}
    </div>
  </body>
</html>
