<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ page_title }}</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='site.css') }}">
  </head>
  <body data-current-page="{{ current_page }}">
    <div class="shell">
      <header class="topbar">
        <a class="brand" href="{{ url_for('home') }}">
          <span class="brand-mark">Research Demo</span>
          <span class="brand-name">Variant Review Workbench</span>
        </a>
        <nav class="nav" aria-label="Primary">
          <a href="{{ url_for('home') }}" class="{% if current_page == 'home' %}active{% endif %}">Home</a>
          <a href="{{ url_for('docs') }}" class="{% if current_page == 'docs' %}active{% endif %}">Overview</a>
        </nav>
      </header>
      <section class="scope-banner" aria-label="Usage scope">
        <strong>Research-use only.</strong>
        <span>This hosted interface demonstrates the pipeline and reporting workflow. It is not a clinical system, privacy boundary, or PHI-ready platform.</span>
      </section>
      {% block content %}{% endblock %}
    </div>
    <script>
      (() => {
        const form = document.querySelector("[data-run-form]");
        if (form) {
          const exportOnly = form.querySelector("[data-export-only]");
          const exportFormatField = form.querySelector("[data-export-format-field]");
          const submitButton = form.querySelector("[data-submit-button]");

          const syncExportVisibility = () => {
            const exportEnabled = Boolean(exportOnly && exportOnly.checked);
            if (exportFormatField) {
              exportFormatField.classList.toggle("hidden", !exportEnabled);
            }
            if (submitButton) {
              submitButton.dataset.loading = "false";
            }
          };

          syncExportVisibility();
          exportOnly?.addEventListener("change", syncExportVisibility);
          form.addEventListener("submit", () => {
            if (submitButton) {
              submitButton.dataset.loading = "true";
              submitButton.setAttribute("aria-disabled", "true");
              submitButton.disabled = true;
            }
          });
        }

        const statusRoot = document.querySelector("[data-run-root]");
        if (!statusRoot) {
          return;
        }

        const runId = statusRoot.dataset.runId;
        const initialStatus = statusRoot.dataset.runStatus;
        if (!runId || !initialStatus || !["queued", "running"].includes(initialStatus)) {
          return;
        }

        const badge = statusRoot.querySelector("[data-status-badge]");
        const statusMessage = statusRoot.querySelector("[data-status-message]");

        const poll = async () => {
          try {
            const response = await fetch(`/runs/${runId}/status`, { headers: { "Accept": "application/json" } });
            if (!response.ok) {
              window.setTimeout(poll, 1500);
              return;
            }
            const payload = await response.json();
            if (badge) {
              badge.textContent = payload.status;
              badge.className = `status-badge ${payload.status}`;
            }
            if (statusMessage) {
              if (payload.status === "running") {
                statusMessage.textContent = "The job is running now. This page will refresh when the report is ready.";
              } else if (payload.status === "queued") {
                statusMessage.textContent = "The job is queued. This page is polling the status endpoint.";
              }
            }
            if (payload.status === "succeeded" || payload.status === "failed") {
              window.location.reload();
            } else {
              window.setTimeout(poll, 1250);
            }
          } catch (_) {
            window.setTimeout(poll, 2000);
          }
        };

        window.setTimeout(poll, 900);
      })();
    </script>
  </body>
</html>
