{% extends "web/base.html.j2" %}

{% block content %}
  <section class="hero" data-run-root data-run-id="{{ run_id }}" data-run-status="{{ job.status }}">
    <div class="status-grid">
      <div>
        <p class="eyebrow">Run</p>
        <h1>Run output</h1>
        <p>
          View the report and download the generated files.
        </p>
        <div class="actions">
          {% if job.result and job.status == "succeeded" %}
            <a class="button" href="{{ url_for('run_export', run_id=run_id, export_format='html') }}">Export HTML</a>
            <a class="button secondary" href="{{ url_for('run_export', run_id=run_id, export_format='json') }}">Export JSON</a>
            <a class="button secondary" href="{{ url_for('run_export', run_id=run_id, export_format='md') }}">Export Markdown</a>
          {% else %}
            <a class="button ghost" href="{{ url_for('home') }}">Start another run</a>
          {% endif %}
        </div>
      </div>
      <div class="meta-card">
        <strong>Run summary</strong>
        <div class="mono">{{ run_id }}</div>
        <div class="subtle-divider"></div>
        <div class="actions-inline">
          <span class="status-badge {{ job.status }}" data-status-badge>{{ job.status }}</span>
        </div>
        <p data-status-message class="muted" style="margin-bottom: 0;">
          {% if job.status == "succeeded" %}
            Report and exports are ready.
          {% elif job.status == "failed" %}
            Run failed.
          {% elif job.status == "running" %}
            Run in progress. This page refreshes automatically.
          {% else %}
            Run queued.
          {% endif %}
        </p>
        <p class="footer-note" style="margin-top: 18px;">
          Research use only. Run files are removed after
          {{ web_scope.run_retention_hours }} hour{% if web_scope.run_retention_hours != 1 %}s{% endif %}.
        </p>
      </div>
    </div>
  </section>

  <section class="panel" style="margin-top: 24px;">
    <div class="panel-header">
      <h2>Job status</h2>
      <span class="mono">{{ url_for('run_status', run_id=run_id) }}</span>
    </div>
    <p class="muted">Use the status endpoint for polling.</p>
    <div class="subtle-divider"></div>
    <div class="status-list">
      <div class="status-item">
        <span>Mode</span>
        <strong class="mono">{{ job.mode }}</strong>
      </div>
      <div class="status-item">
        <span>Requested export</span>
        <strong class="mono">{{ job.export_format or "None" }}</strong>
      </div>
      <div class="status-item">
        <span>Current status</span>
        <strong>{{ job.status }}</strong>
      </div>
      {% if job.result %}
        <div class="status-item">
          <span>Uploaded VCF</span>
          <strong class="mono">{{ job.result.uploaded_vcf_path }}</strong>
        </div>
        <div class="status-item">
          <span>Run output directory</span>
          <strong class="mono">{{ job.result.output_dir }}</strong>
        </div>
        <div class="status-item">
          <span>Summary artifact</span>
          <strong class="mono">{{ job.result.summary_json_path }}</strong>
        </div>
        <div class="status-item">
          <span>Report JSON export</span>
          <strong class="mono">{{ job.result.report_json_path }}</strong>
        </div>
        <div class="status-item">
          <span>Report Markdown export</span>
          <strong class="mono">{{ job.result.report_markdown_path }}</strong>
        </div>
      {% elif job.error %}
        <div class="status-item">
          <span>Error</span>
          <strong class="mono">{{ job.error }}</strong>
        </div>
      {% endif %}
    </div>
  </section>

  {% if job.result and job.status == "succeeded" %}
    <section class="panel" style="margin-top: 24px;">
      <div class="fact-grid">
        <div class="fact-card">
          <strong>Input Variants</strong>
          <span class="metric">{{ job.result.summary.input_variant_count }}</span>
          <p>Variant records processed in this run.</p>
        </div>
        <div class="fact-card">
          <strong>ClinVar Matches</strong>
          <span class="metric">{{ job.result.summary.clinvar_matched_count }}</span>
          <p>Matched records in the configured ClinVar data.</p>
        </div>
        <div class="fact-card">
          <strong>Conflicts</strong>
          <span class="metric">{{ job.result.summary.conflict_flagged_count }}</span>
          <p>Records flagged for conflict review.</p>
        </div>
        <div class="fact-card">
          <strong>Web Variant Cap</strong>
          <span class="metric">{{ job.result.max_input_variants }}</span>
          <p>Maximum variant records processed per web run.</p>
        </div>
      </div>
      {% if job.result.summary.input_variant_count > 0 and job.result.summary.clinvar_matched_count == 0 %}
        <div class="notice warning" style="margin-top: 16px;">
          <strong>No ClinVar matches found.</strong>
          <p>
            All variants were assigned <code>context_only</code>. Check the selected assembly
            (<code>{{ job.result.assembly }}</code>) and the configured ClinVar data.
          </p>
        </div>
      {% endif %}
    </section>

    <section class="panel" style="margin-top: 24px; padding: 16px;">
      <div class="panel-header" style="padding: 12px 12px 0;">
        <h2>Report Preview</h2>
        <a class="button ghost" href="{{ url_for('run_report', run_id=run_id) }}" target="_blank" rel="noopener noreferrer">Open HTML Report</a>
      </div>
      <iframe
        title="Variant Review Report"
        src="{{ url_for('run_report', run_id=run_id) }}"
        class="report-frame"
      ></iframe>
    </section>
  {% else %}
    <section class="panel" style="margin-top: 24px;">
      <h2>Status</h2>
      {% if job.error %}
        <div class="notice error">
          <strong>Run failed</strong>
          <p>{{ job.error }}</p>
        </div>
      {% else %}
        <div class="notice">
          <strong>Waiting for output</strong>
          <p>The report preview appears when the run succeeds.</p>
        </div>
      {% endif %}
      <ul>
        <li>The report preview appears here when ready.</li>
        <li>Web runs process at most {{ web_scope.max_input_variants }} variants.</li>
        <li>Export buttons appear after the run succeeds.</li>
        <li>Files remain tied to this run workspace.</li>
      </ul>
      <p class="footer-note">Do not upload patient-identifying data.</p>
    </section>
  {% endif %}
{% endblock %}
