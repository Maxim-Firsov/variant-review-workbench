<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ page_title }}</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='site.css') }}">
  </head>
  <body data-current-page="{{ current_page }}">
    <div class="shell">
      <header class="topbar">
        <a class="brand" href="{{ url_for('home') }}">
          <span class="brand-mark">Web Tool</span>
          <span class="brand-name">Variant Review Workbench</span>
        </a>
        <nav class="nav" aria-label="Primary">
          <a href="{{ url_for('home') }}" class="{% if current_page == 'home' %}active{% endif %}">Run</a>
          <a href="{{ url_for('docs') }}" class="{% if current_page == 'docs' %}active{% endif %}">Usage</a>
        </nav>
      </header>
      <section class="scope-banner" aria-label="Usage scope">
        <strong>Research use only.</strong>
        <span>Do not upload patient-identifying data.</span>
      </section>
      {% block content %}{% endblock %}
    </div>
    <script>
      (() => {
        const form = document.querySelector("[data-run-form]");
        if (form) {
          const exportOnly = form.querySelector("[data-export-only]");
          const exportFormatField = form.querySelector("[data-export-format-field]");
          const submitButton = form.querySelector("[data-submit-button]");

          const syncExportVisibility = () => {
            const exportEnabled = Boolean(exportOnly && exportOnly.checked);
            if (exportFormatField) {
              exportFormatField.classList.toggle("hidden", !exportEnabled);
            }
            if (submitButton) {
              submitButton.dataset.loading = "false";
            }
          };

          syncExportVisibility();
          exportOnly?.addEventListener("change", syncExportVisibility);
          form.addEventListener("submit", () => {
            if (submitButton) {
              submitButton.dataset.loading = "true";
              submitButton.setAttribute("aria-disabled", "true");
              submitButton.disabled = true;
            }
          });
        }

        const statusRoot = document.querySelector("[data-run-root]");
        if (!statusRoot) {
          return;
        }

        const initialStatus = statusRoot.dataset.runStatus;
        if (!initialStatus || !["queued", "running"].includes(initialStatus)) {
          return;
        }
        window.setTimeout(() => window.location.reload(), 3000);
      })();
    </script>
  </body>
</html>
