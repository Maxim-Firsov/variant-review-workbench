{% extends "web/base.html.j2" %}

{% block content %}
  <section class="hero">
    <div class="hero-grid">
      <div>
        <p class="eyebrow">VCF Review</p>
        <div class="chip-row">
          <span class="chip">VCF input</span>
          <span class="chip">ClinVar matching</span>
          <span class="chip">HTML / JSON / Markdown</span>
        </div>
        <h1>Variant Review Workbench</h1>
        <p class="hero-lead">
          Upload a VCF, choose the assembly, and generate a report with export files.
        </p>
        <p>
          Runs use the shared ClinVar cache. Run files are removed after
          {{ web_scope.run_retention_hours }} hour{% if web_scope.run_retention_hours != 1 %}s{% endif %}.
        </p>
        <div class="actions">
          <a class="button" href="#run-setup">New run</a>
          <a class="button ghost" href="{{ url_for('docs') }}">Usage</a>
        </div>
      </div>
      <div class="meta-card">
        <strong>Tool summary</strong>
        <p>Input: `.vcf` or `.vcf.gz`. Output: report preview plus HTML, JSON, and Markdown exports.</p>
        <dl class="data-list">
          <div>
            <dt>Upload limit</dt>
            <dd>{{ web_scope.max_upload_mb }} MB</dd>
          </div>
          <div>
            <dt>Assemblies</dt>
            <dd>GRCh37 / GRCh38</dd>
          </div>
          <div>
            <dt>Retention window</dt>
            <dd>{{ web_scope.run_retention_hours }}h run cleanup</dd>
          </div>
        </dl>
      </div>
    </div>
  </section>

  <section class="panel" style="margin-top: 24px;">
    <div class="fact-grid">
      <div class="fact-card">
        <strong>Input</strong>
        <span class="metric">VCF</span>
        <p>Accepts `.vcf` and `.vcf.gz` uploads up to {{ web_scope.max_upload_mb }} MB.</p>
      </div>
      <div class="fact-card">
        <strong>Pipeline</strong>
        <span class="metric">Shared</span>
        <p>Uses the same run pipeline and report outputs as the CLI.</p>
      </div>
      <div class="fact-card">
        <strong>Outputs</strong>
        <span class="metric">3 Formats</span>
        <p>Open the report in the browser or download HTML, JSON, or Markdown.</p>
      </div>
    </div>
  </section>

  <section class="panel" id="run-setup" style="margin-top: 24px;">
    <h2>Run Setup</h2>
    <p class="muted">Upload a file, select the assembly, and choose the output mode.</p>
    <div class="subtle-divider"></div>
    <form class="stack" method="post" action="{{ url_for('create_run') }}" enctype="multipart/form-data" data-run-form>
      {% if form_error %}
        <div class="notice error">
          <strong>Input error</strong>
          <p>{{ form_error }}</p>
        </div>
      {% endif %}
      <div class="grid-two">
        <div class="field">
          <label for="vcf_file">VCF upload</label>
          <div class="actions-inline">
            <input id="vcf_file" name="vcf_file" type="file" accept=".vcf,.vcf.gz,.gz" {% if not form_use_demo_sample %}required{% endif %}>
            <label class="check" for="use_demo_sample" style="margin: 0;">
              <input id="use_demo_sample" name="use_demo_sample" type="checkbox" value="true" data-use-demo-sample {% if form_use_demo_sample %}checked{% endif %}>
              <span>Use demo sample</span>
            </label>
          </div>
          <div class="field hidden" data-demo-sample-field>
            <label for="demo_sample_id">Demo sample</label>
            <select id="demo_sample_id" name="demo_sample_id">
              <option value="{{ web_scope.demo_sample.id }}" {% if form_demo_sample_id == web_scope.demo_sample.id %}selected{% endif %}>
                {{ web_scope.demo_sample.label }}
              </option>
            </select>
            <small>
              Genes: {{ web_scope.demo_sample.genes | join(", ") }}.
              Loci: {{ web_scope.demo_sample.loci | join(", ") }}.
              Source: {{ web_scope.demo_sample.source }}.
            </small>
          </div>
          <small>Select a local `.vcf` or `.vcf.gz` file, or use the hosted demo sample.</small>
        </div>

        <div class="field">
          <label for="assembly">Assembly</label>
          <select id="assembly" name="assembly" data-assembly-select>
            <option value="GRCh38" {% if form_assembly == "GRCh38" %}selected{% endif %}>GRCh38</option>
            <option value="GRCh37" {% if form_assembly == "GRCh37" %}selected{% endif %}>GRCh37</option>
          </select>
          <small>Match the assembly to the VCF coordinates.</small>
        </div>
      </div>

      <fieldset class="fieldset">
        <legend>Options</legend>
        <div class="checklist" style="margin-bottom: 14px;">
          <label class="check" for="enable_pharmgkb">
            <input id="enable_pharmgkb" name="enable_pharmgkb" type="checkbox" value="true">
            <span>Include PharmGKB enrichment</span>
          </label>
          <label class="check" for="mode_export_only">
            <input id="mode_export_only" name="mode" type="checkbox" value="export_only" data-export-only>
            <span>Return export only</span>
          </label>
        </div>
        <div class="field">
          <label for="max_input_variants">Variant limit</label>
          <input
            id="max_input_variants"
            name="max_input_variants"
            type="number"
            min="5"
            max="{{ web_scope.max_input_variants }}"
            step="1"
            value="{{ form_max_input_variants | default(web_scope.max_input_variants) }}"
            required
          >
          <small>Integer from 5 to {{ web_scope.max_input_variants }}. Default: {{ web_scope.max_input_variants }}.</small>
        </div>
      </fieldset>

      <div class="field" data-export-format-field>
        <label for="export_format">Preferred export format</label>
        <select id="export_format" name="export_format">
          <option value="json">JSON</option>
          <option value="html">HTML</option>
          <option value="md">Markdown</option>
        </select>
        <small>Used only with export-only mode.</small>
      </div>

      <div class="notice">
        <strong>Data handling</strong>
        <p>Uploads are stored per run and removed by cleanup. Do not upload patient-identifying data.</p>
      </div>

      <div class="actions">
        <button type="submit" data-submit-button data-loading="false">
          <span class="loading-label-default">Run</span>
          <span class="loading-label-active">Submitting...</span>
        </button>
        <a class="button secondary" href="{{ url_for('docs') }}">Usage</a>
      </div>
      <p class="footer-note">Max web run size: {{ web_scope.max_input_variants }} variants.</p>
    </form>
  </section>
{% endblock %}
