{% extends "web/base.html.j2" %}

{% block content %}
  <section class="hero">
    <p class="eyebrow">Usage</p>
    <h1>Variant Review Workbench</h1>
    <p>
      Use this interface to run the web workflow and download the generated outputs.
    </p>
    <div class="actions">
      <a class="button" href="{{ url_for('home') }}">Open run form</a>
      <a class="button ghost" href="https://github.com/Maxim-Firsov/variant-review-workbench" target="_blank" rel="noreferrer">Repository</a>
    </div>
  </section>

  <section class="panel" style="margin-top: 24px;">
    <div class="docs-grid">
      <div class="doc-card">
        <strong>Input</strong>
        <p>Upload one `.vcf` or `.vcf.gz` file and select `GRCh37` or `GRCh38`.</p>
      </div>
      <div class="doc-card">
        <strong>Processing</strong>
        <p>The web run uses the same pipeline and report generator as the CLI.</p>
      </div>
      <div class="doc-card">
        <strong>Scope</strong>
        <p>Research use only. Do not upload patient-identifying data.</p>
      </div>
    </div>
  </section>

  <section class="panel" style="margin-top: 24px;">
    <div class="panel-grid">
      <div>
        <h2>Steps</h2>
        <ul>
          <li>Upload a `.vcf` or `.vcf.gz` file.</li>
          <li>Select `GRCh37` or `GRCh38`.</li>
          <li>Optionally include PharmGKB enrichment.</li>
          <li>Open the report or download HTML, JSON, or Markdown.</li>
        </ul>
      </div>
      <div>
        <h2>Outputs</h2>
        <ul>
          <li>Report preview in the browser.</li>
          <li>HTML, JSON, and Markdown exports.</li>
          <li>Status endpoint for polling.</li>
          <li>Run summary and metadata files.</li>
        </ul>
      </div>
    </div>
    <p class="footer-note">Web runs process at most {{ web_scope.max_input_variants }} variants.</p>
  </section>

  <section class="panel" style="margin-top: 24px;">
    <div class="panel-grid">
      <div>
        <h2>Limits</h2>
        <ul>
          <li>Upload limit: {{ web_scope.max_upload_mb }} MB.</li>
          <li>Run retention: about {{ web_scope.run_retention_hours }} hour{% if web_scope.run_retention_hours != 1 %}s{% endif %}.</li>
          <li>No patient-identifying data.</li>
        </ul>
      </div>
      <div>
        <h2>Runtime</h2>
        <ul>
          <li>The site reuses a shared ClinVar cache.</li>
          <li>Uploads are stored in per-run workspaces.</li>
          <li>Use `/healthz` to check service status.</li>
        </ul>
      </div>
    </div>
  </section>
{% endblock %}
